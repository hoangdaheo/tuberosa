NODE_ENV=development
PORT=3027
TUBEROSA_API_KEY=
DATABASE_URL=postgres://tuberosa:tuberosa@localhost:5432/tuberosa
POSTGRES_PASSWORD=tuberosa
REDIS_URL=redis://localhost:6379
TUBEROSA_STORE=postgres
TUBEROSA_CACHE=redis
TUBEROSA_MODEL_PROVIDER=hash
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_REWRITE_MODEL=
OPENAI_RERANK_MODEL=
EMBEDDING_DIMENSIONS=1536
CONTEXT_CACHE_TTL_SECONDS=300
TUBEROSA_MAX_REQUEST_BYTES=10485760
TUBEROSA_MAX_INGEST_CONTENT_BYTES=2097152
TUBEROSA_BACKUP_DIR=.tuberosa/backups
