{
  "name": "tuberosa",
  "version": "0.1.0",
  "description": "Local-first MCP context broker for agentic AI knowledge matching and reflection memory.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "mcp": "tsx src/mcp-stdio.ts",
    "worker": "tsx src/worker.ts",
    "migrate": "tsx scripts/migrate.ts",
    "test": "node --test --import tsx test/*.test.ts"
  },
  "dependencies": {
    "pg": "^8.13.1",
    "redis": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.17.10",
    "@types/pg": "^8.11.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  },
  "engines": {
    "node": ">=20"
  }
}
